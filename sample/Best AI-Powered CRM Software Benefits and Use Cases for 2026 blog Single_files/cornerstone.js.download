(function($){if($('.cornerstone-content')[0]){const bsH2=document.querySelectorAll('.cornerstone-content .text-block');let scrollSpyMenu=document.querySelector('.scrollspy-menu');let scrollSpyItemData=[];let scrollSpyMenuClone;scrollSpyMenu.innerHTML='';for(n=0,length=bsH2.length;n<length;n++){bsH2[n].id="text-block-"+(n+1);let id=bsH2[n].getAttribute('data-id');let parentId=bsH2[n].getAttribute('data-parent');let scrollSpyLink=createScrollSpyLink(n,id,parentId);let scrollSpyItem=document.createElement('div');if(scrollSpyLink.textContent){scrollSpyItem.className='scrollspy-item';scrollSpyItem.appendChild(scrollSpyLink)}
if(document.body.classList.contains('monster-tmpl')){const parentArr=document.getElementById('all_parent_ids').value.split(",");if(parentArr.includes(id)){createSctollSpySubmenu(id,scrollSpyLink,scrollSpyItem)}
if(scrollSpyLink.textContent){parentId==0?scrollSpyMenu.appendChild(scrollSpyItem):document.getElementById('submenu-'+parentId).appendChild(scrollSpyItem)}}else{if(scrollSpyLink.textContent){scrollSpyMenu.appendChild(scrollSpyItem)}}
scrollSpyItemData.push([scrollSpyItem.textContent,scrollSpyLink]);const subTitles=bsH2[n].querySelectorAll('h3.sub-title');subTitles.forEach((subTitle,index)=>{const link=document.createElement('a');link.className='scrollspy-link scroll inner';link.href=`#sub-title-${n}-${index}`;link.textContent=subTitle.textContent;const div=document.createElement('div');div.className='scrollspy-item scrollspy-item-inner';div.appendChild(link);scrollSpyMenu.appendChild(div);subTitle.id=`sub-title-${n}-${index}`});$('.scrollspy-item').each(function(){var $this=$(this);if(!$this.hasClass('scrollspy-item-inner')){var $nextElement=$this.next('.scrollspy-item');if($nextElement.hasClass('scrollspy-item-inner')){$this.addClass('scrollspy-main-item')}}})}
scrollSpyMenuClone=scrollSpyMenu.cloneNode(!0);let simplebar=new SimpleBar(document.querySelector('.scrollspy-menu'));function createScrollSpyLink(n,id,parentId){scrollSpyLink=document.createElement('a');scrollSpyLink.className='scrollspy-link scroll';scrollSpyLink.setAttribute('href','#text-block-'+(n+1));scrollSpyLink.setAttribute('id','scroll-'+(n+1));scrollSpyLink.setAttribute('data-parentid',parentId);scrollSpyLink.textContent=$('#text-block-'+(n+1)+' .text-block__title').text();return scrollSpyLink}
function createSctollSpySubmenu(id,scrollSpyLink,scrollSpyItem){const scrollSpySubmenu=document.createElement('div');const scrollSpyBtn=document.createElement('button');const scrollSpyParentDiv=document.createElement('div');scrollSpyParentDiv.className='scrollspy-parent';scrollSpySubmenu.className='scrollspy-submenu collapse';scrollSpySubmenu.setAttribute('id','submenu-'+id);scrollSpySubmenu.setAttribute('data-parent','#accordion-scrollspy-menu');scrollSpyBtn.className='scrollspy-btn';scrollSpyBtn.setAttribute('aria-label',scrollSpyLink.innerText);setAccordionItem(scrollSpyBtn,id);setAccordionItem(scrollSpyLink,id);scrollSpyParentDiv.appendChild(scrollSpyLink);scrollSpyParentDiv.appendChild(scrollSpyBtn);scrollSpyItem.appendChild(scrollSpyParentDiv);scrollSpyItem.appendChild(scrollSpySubmenu)}
function setAccordionItem(el,id){el.setAttribute('data-toggle','collapse');el.setAttribute('data-target','#submenu-'+id);el.setAttribute('aria-controls','#submenu-'+id);el.setAttribute('aria-expanded','false')}
function searchItems(e){el=e.target;searchTerm=e.target.value.toLowerCase();if(searchTerm.length>0){doSearch(searchTerm)}else{searchClear()}}
function doSearch(searchTerm){simplebar.unMount();scrollSpyMenu.innerHTML='';for(i=0,length=scrollSpyItemData.length;i<length;i++){let item=scrollSpyItemData[i][0].toLowerCase();if(item.includes(searchTerm)){let foundScrollSpyItem=document.createElement('li');foundScrollSpyItem.className='scrollspy-item';foundScrollSpyItem.appendChild(scrollSpyItemData[i][1]);scrollSpyMenu.appendChild(foundScrollSpyItem)}}
scrollSpyMenu.classList.add('scrollspy-search-results');new SimpleBar(document.querySelector('.scrollspy-search-results'))}
function searchClear(){scrollSpyMenu.remove();scrollSpyMenu=scrollSpyMenuClone.cloneNode(!0)
document.querySelectorAll('.scrollspy-sidebar')[0].appendChild(scrollSpyMenu);scrollSpyMenu.classList.remove('scrollspy-search-results');reinvokeCustomScrollbar('.scrollspy-menu');smoothScrollonClick()}
function reinvokeCustomScrollbar(elClass){let el=document.querySelector(elClass)
let simplebar=new SimpleBar(el);simplebar.recalculate()}
$('#scrollspy-search').on("input",searchItems);$('.scrollspy-search-clear').on('click',function(e){document.getElementById('scrollspy-search').value='';searchClear()})}
var smoothScrollonClicked=!1;function smoothScrollonClick(){$('.scroll').on('click',function(e){e.preventDefault();smoothScrollonClicked=!0;var currLink=$(this);const parentId=currLink.data('parentid');var refElement=$(currLink.attr('href'));var scrollDistance=refElement.offset().top-($(window).height()/2)+1;$('html, body').animate({'scrollTop':scrollDistance},1000,'swing',function(){smoothScrollonClicked=!1;$('.scroll, .text-block__title').removeClass('active');currLink.addClass('active');refElement.children().first().addClass("active");if(parentId!=0){$(".scrollspy-link[data-target='#submenu-"+parentId+"'").addClass("active-parent")}else{$(".scrollspy-link").removeClass("active-parent")}
if(document.body.classList.contains('monster-tmpl')){console.log('monster-tmpl');currentStickyHeadingEl=getScrollSpyStickyHeading(prevStickyHeadingEl);prevStickyHeadingEl=currentStickyHeadingEl}});if(e.target.classList.contain='expander__action__button'){return}
if(currLink.closest('.scrollspy-submenu').length>0&&$(window).width()<992||currLink.closest('.scrollspy-parent').length==0&&$(window).width()<992){console.log('triggered auto close');$('.scrollspy-current').trigger("click")}})}
function setReadingTime(){const content=document.getElementById('article-section').textContent;const wordCount=content.replace(/[^\w ]/g,"").split(/\s+/).length;const readingTimeEl=document.getElementById('reading-time');if(readingTimeEl){readingTimeEl.innerHTML=Math.ceil(wordCount/200)}}
var prevStickyHeadingEl;var currentStickyHeadingEl;function scrollSpy(){if(document.body.querySelector('.scrollspy')){console.log('scrollspy');const scrollDistance=$(this).scrollTop()+($(this).height()/2);$(".scrollspy-menu .scrollspy-item a[href^='#']").each(function(){const currLink=$(this);const parentId=currLink.data('parentid');const refElement=$(currLink.attr("href"));if(refElement.offset().top<=scrollDistance){$(".scrollspy-menu .scrollspy-item a, .text-block__title").removeClass("active");currLink.addClass("active");refElement.children().first().addClass("active");if(parentId!=0){$(".scrollspy-link[data-target='#submenu-"+parentId+"'").addClass("active-parent")}else{$(".scrollspy-link").removeClass("active-parent")}}});if(document.body.classList.contains('monster-tmpl')){let articleBottomOffset=window.pageYOffset+document.querySelector("#article-section").getBoundingClientRect().bottom;let articleTopOffset=window.pageYOffset+document.querySelector(".cornerstone-content").getBoundingClientRect().top;currentStickyHeadingEl=getScrollSpyStickyHeading(prevStickyHeadingEl);if(currentStickyHeadingEl!=prevStickyHeadingEl){let id=currentStickyHeadingEl.parentElement.getAttribute('id').split('-')[2];let scrollSpyLink=document.querySelector('#scroll-'+id);if(scrollSpyLink.getAttribute("aria-expanded")=='false'){if($.isFunction($.fn.collapse)){$(scrollSpyLink.parentElement.nextElementSibling).collapse('toggle')}else{scrollSpyLink.setAttribute("aria-expanded",'true');scrollSpyLink.nextElementSibling.setAttribute("aria-expanded",'true');scrollSpyLink.parentElement.nextElementSibling.classList.add('show')}}}
prevStickyHeadingEl=currentStickyHeadingEl;if(articleBottomOffset<scrollDistance||window.pageYOffset<articleTopOffset){$('.scrollspy-sticky-heading').remove()}}}}
function cloneScrollSpyStickyHeadingEl(el,text){contentHeadingElSticky=el.cloneNode(!0);contentHeadingElSticky.classList.add('scrollspy-sticky-heading');contentHeadingElSticky.innerText=text;contentHeadingElSticky.style.maxWidth=document.getElementById('article-section').offsetWidth+'px';el.parentElement.appendChild(contentHeadingElSticky)}
function getScrollSpyStickyHeading(prevStickyHeading){const activeHeadings=document.querySelectorAll('.scrollspy-link.active, .scrollspy-link.active-parent');let scrollSpyStickyHeading='';let contentHeadingEl=null;let contentHeadingElSticky=null;if(activeHeadings.length){contentHeadingEl=document.querySelector(activeHeadings[0].getAttribute('href')+' .h2.text-block__title');scrollSpyStickyHeading=activeHeadings[0].textContent}else{scrollSpyStickyHeading=''}
$('.scrollspy-sticky-heading').remove();if(prevStickyHeading!=contentHeadingEl){if(prevStickyHeading){cloneScrollSpyStickyHeadingEl(prevStickyHeading,scrollSpyStickyHeading)}}
if(contentHeadingEl){if(!$(contentHeadingEl).parent().find('.scrollspy-sticky-heading').length){cloneScrollSpyStickyHeadingEl(contentHeadingEl,scrollSpyStickyHeading)}}
return contentHeadingEl}
function scrollspyContentMenu(){$('.scrollspy-current').on('click',function(e){e.preventDefault;$('.scrollspy-sidebar').slideToggle();$('.scrollspy-block').toggleClass('active')});$('.scrollspy-menu-overlay').on('click',function(e){$('.scrollspy-block').removeClass('active');$('.scrollspy-sidebar').slideUp()});if($(window).width()<992){$('a.scroll').on('click',function(){$('.scrollspy-block').removeClass('active');$('.scrollspy-sidebar').slideUp()})}}
smoothScrollonClick();scrollSpy();scrollspyContentMenu();window.onscroll=function(){if(!1===smoothScrollonClicked){scrollSpy()}else{}}
window.onresize=function(){if(document.querySelector('.scrollspy-sticky-heading')){document.querySelector('.scrollspy-sticky-heading').style.maxWidth=document.getElementById('article-section').offsetWidth+'px'}}})(jQuery)