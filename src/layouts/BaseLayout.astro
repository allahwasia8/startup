---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Your trusted partner for starting, growing, and scaling your business in the UK." } = Astro.props;

// Compute canonical URL and strip trailing slash to match internal links consistently
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalURL = new URL(pathname, Astro.site || 'https://ukstartupflow.com');
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-752HTTXGXT"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-752HTTXGXT');
		</script>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<title>{title} | UK Startup Flow</title>
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | UK Startup Flow`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/images/london-hero.jpg', canonicalURL)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | UK Startup Flow`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL('/images/london-hero.jpg', canonicalURL)} />
		<slot name="head" />
	</head>
	<body>
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
