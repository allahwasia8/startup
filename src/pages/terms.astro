<style>
  .legal-page {
    padding: 80px 0;
    background-color: #ffffff;
    min-height: 70vh;
  }

  .legal-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .legal-container h1 {
    font-size: 40px;
    font-weight: 800;
    color: #0b2242;
    margin-bottom: 8px;
    font-family: var(--font-heading, sans-serif);
  }

  .last-updated {
    font-size: 15px;
    color: #718096;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid #edf2f7;
  }

  .legal-section {
    margin-bottom: 40px;
  }

  .legal-section h2 {
    font-size: 22px;
    font-weight: 700;
    color: #0b2242;
    margin-bottom: 16px;
    font-family: var(--font-heading, sans-serif);
  }

  .legal-section p {
    font-size: 16px;
    color: #4a5568;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .legal-section ul {
    margin-top: 0;
    margin-bottom: 24px;
    padding-left: 24px;
    color: #4a5568;
  }

  .legal-section li {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 8px;
  }

  .legal-section a {
    color: #d6182a;
    text-decoration: none;
  }

  .legal-section a:hover {
    text-decoration: underline;
  }
</style>
