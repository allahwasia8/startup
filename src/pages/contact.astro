---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us">
  <div class="contact-page">
    <div class="hero-ribbon"></div>
    
    <div class="container contact-container">
      <!-- Left Column: Contact Info -->
      <div class="contact-info">
        <h1 class="contact-title">Let's build something<br><span class="text-red">great together.</span></h1>
        <p class="contact-subtitle">Have a question, partnership idea, or just want to say hello? We'd love to hear from you.</p>
        
        <h2 class="contact-section-title">Get in touch</h2>
        
        <div class="contact-details">
          <div class="detail-item">
            <div class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div class="detail-text">
              <strong>Address</strong>
              <span>71-75 Shelton Street, Covent Garden,<br>London, WC2H 9JQ, United Kingdom</span>
            </div>
          </div>
          
          <div class="detail-item">
            <div class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div class="detail-text">
              <strong>Email</strong>
              <span>hello@ukstartupflow.com</span>
            </div>
          </div>
          
          <div class="detail-item">
            <div class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div class="detail-text">
              <strong>Phone</strong>
              <span>+44 20 3868 0836</span>
            </div>
          </div>
          
          <div class="detail-item">
            <div class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div class="detail-text">
              <strong>Hours</strong>
              <span>Monday – Friday<br>9:00 AM – 5:00 PM (GMT)</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right Column: Form Card -->
      <div class="contact-form-wrapper">
        <div class="form-card">
          <h3 class="form-title">Send us a message</h3>
          <p class="form-subtitle">Fill out the form below and we'll get back to you as soon as possible.</p>
          
          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <input type="text" placeholder="Full Name" class="form-input" required />
              <input type="email" placeholder="Email Address" class="form-input" required />
            </div>
            <div class="form-row full-width">
              <input type="text" placeholder="Company Name (Optional)" class="form-input" />
            </div>
            <div class="form-row full-width">
              <div class="select-wrapper">
                <select class="form-select" required>
                  <option value="" disabled selected>What can we help you with?</option>
                  <option value="general">General Inquiry</option>
                  <option value="support">Support</option>
                  <option value="partnership">Partnership</option>
                  <option value="other">Other</option>
                </select>
                <svg class="select-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
            </div>
            <div class="form-row full-width">
              <textarea placeholder="Your Message" rows="5" class="form-textarea" required></textarea>
            </div>
            
            <div class="form-footer">
              <button type="submit" class="btn-submit">Send Message &rarr;</button>
              <div class="privacy-note">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a0aec0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
                <span>We respect your privacy. Your information<br>will never be shared.</span>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
    
    <!-- Bottom Banner -->
    <div class="features-banner">
      <div class="container features-container">
        <div class="feature-box">
          <div class="feature-box-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path><path d="M8 10h.01"></path><path d="M12 10h.01"></path><path d="M16 10h.01"></path></svg>
          </div>
          <div class="feature-box-text">
            <h4>We're here to help</h4>
            <p>Our team is ready to support your startup journey.</p>
          </div>
        </div>
        
        <div class="feature-box">
          <div class="feature-box-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <div class="feature-box-text">
            <h4>Expert guidance</h4>
            <p>Get answers from experienced founders and advisors.</p>
          </div>
        </div>
        
        <div class="feature-box">
          <div class="feature-box-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M9 15l2 2 4-4"></path></svg>
          </div>
          <div class="feature-box-text">
            <h4>Fast response</h4>
            <p>We aim to respond to all inquiries within 24 hours.</p>
          </div>
        </div>
        
        <div class="feature-box">
          <div class="feature-box-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 6.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 8.7 1.46 12.14 3.58 14.26l.77.78L12 22.68l7.65-7.64.77-.78c2.12-2.12 2.12-5.56 0-7.68z"></path></svg>
          </div>
          <div class="feature-box-text">
            <h4>Partnership opportunities</h4>
            <p>Let's explore how we can work together.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    position: relative;
    background-color: #f8fbff;
    padding-top: 60px;
    min-height: calc(100vh - 80px);
    overflow: hidden;
  }

  .hero-ribbon {
    position: absolute;
    top: -50px;
    right: -100px;
    width: 600px;
    height: 300px;
    background: linear-gradient(to bottom, #d6182a 0%, #d6182a 33%, #ffffff 33%, #ffffff 66%, #0b2242 66%, #0b2242 100%);
    transform: rotate(35deg);
    border-radius: 50%;
    opacity: 0.9;
    z-index: 0;
  }

  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    position: relative;
    z-index: 10;
    margin-bottom: 60px;
  }

  /* Left Column */
  .contact-info {
    padding-top: 20px;
  }

  .contact-title {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.1;
    color: #0b2242;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    font-family: var(--font-heading, sans-serif);
  }

  .text-red {
    color: #d6182a;
  }

  .contact-subtitle {
    font-size: 18px;
    line-height: 1.6;
    color: #4a5568;
    margin-bottom: 48px;
  }

  .contact-section-title {
    font-size: 24px;
    font-weight: 700;
    color: #0b2242;
    margin-bottom: 24px;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .detail-item {
    display: flex;
    gap: 16px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e2e8f0;
  }

  .detail-item:last-child {
    border-bottom: none;
  }

  .detail-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #eef2f6;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0b2242;
    flex-shrink: 0;
  }

  .detail-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-text strong {
    font-size: 16px;
    font-weight: 600;
    color: #0b2242;
  }

  .detail-text span {
    font-size: 15px;
    color: #4a5568;
    line-height: 1.5;
  }

  /* Right Column (Form) */
  .contact-form-wrapper {
    position: relative;
    z-index: 10;
  }

  .form-card {
    background: #ffffff;
    border-radius: 12px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    border: 1px solid #edf2f7;
  }

  .form-title {
    font-size: 28px;
    font-weight: 700;
    color: #0b2242;
    margin-bottom: 12px;
  }

  .form-subtitle {
    font-size: 15px;
    color: #718096;
    margin-bottom: 32px;
    line-height: 1.5;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-row.full-width {
    grid-template-columns: 1fr;
  }

  .form-input, .form-textarea, .form-select {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    font-size: 15px;
    font-family: inherit;
    color: #2d3748;
    transition: border-color 0.2s ease;
    background-color: #fafbfc;
    box-sizing: border-box;
  }

  .form-input::placeholder, .form-textarea::placeholder {
    color: #a0aec0;
  }

  .form-input:focus, .form-textarea:focus, .form-select:focus {
    outline: none;
    border-color: #3182ce;
    background-color: #ffffff;
  }

  .form-textarea {
    resize: vertical;
  }

  .select-wrapper {
    position: relative;
  }

  .form-select {
    appearance: none;
    cursor: pointer;
    color: #718096;
  }

  .select-icon {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #718096;
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 12px;
  }

  .btn-submit {
    background-color: #0b2242;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 14px 28px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .btn-submit:hover {
    background-color: #1a365d;
  }

  .privacy-note {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .privacy-note span {
    font-size: 12px;
    line-height: 1.4;
    color: #a0aec0;
  }

  /* Bottom Banner */
  .features-banner {
    background-color: #f7fafc;
    border-top: 1px solid #edf2f7;
    padding: 40px 0;
  }

  .features-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .feature-box {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .feature-box-icon {
    color: #0b2242;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .feature-box-text h4 {
    font-size: 15px;
    font-weight: 700;
    color: #0b2242;
    margin-bottom: 4px;
  }

  .feature-box-text p {
    font-size: 13px;
    color: #718096;
    line-height: 1.5;
  }

  /* Responsive Design */
  @media (max-width: 992px) {
    .contact-container {
      grid-template-columns: 1fr;
    }
    
    .features-container {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .hero-ribbon {
      display: none; /* Hide on smaller screens */
    }
  }

  @media (max-width: 640px) {
    .contact-title {
      font-size: 36px;
    }
    
    .form-row {
      grid-template-columns: 1fr;
    }
    
    .form-footer {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .features-container {
      grid-template-columns: 1fr;
    }
    
    .form-card {
      padding: 24px;
    }
  }
</style>
