---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy">
  <div class="legal-page">
    <div class="container legal-container">
      <h1>Privacy Policy</h1>
      <p class="last-updated">Last Updated: June 20, 2026</p>

      <section class="legal-section">
        <h2>1. Introduction</h2>
        <p>UKStartupFlow is committed to protecting your privacy and personal information.</p>
        <p>This Privacy Policy explains how we collect, use, store, and protect your personal data.</p>
      </section>

      <section class="legal-section">
        <h2>2. Information We Collect</h2>
        <h3>Information You Provide</h3>
        <p>We may collect:</p>
        <ul>
          <li>Name</li>
          <li>Email address</li>
          <li>Company name</li>
          <li>Startup name</li>
          <li>Phone number</li>
          <li>Business information</li>
          <li>Messages submitted through forms</li>
        </ul>
        
        <h3>Automatically Collected Data</h3>
        <p>We may collect:</p>
        <ul>
          <li>IP address</li>
          <li>Browser type</li>
          <li>Device information</li>
          <li>Website activity</li>
          <li>Referral source</li>
          <li>Cookie data</li>
        </ul>
      </section>

      <section class="legal-section">
        <h2>3. How We Use Your Information</h2>
        <p>We use information to:</p>
        <ul>
          <li>Deliver requested services</li>
          <li>Respond to inquiries</li>
          <li>Improve Platform functionality</li>
          <li>Provide startup resources</li>
          <li>Send newsletters and updates</li>
          <li>Prevent fraud and abuse</li>
          <li>Comply with legal obligations</li>
        </ul>
      </section>

      <section class="legal-section">
        <h2>4. Legal Basis for Processing</h2>
        <p>Where UK GDPR applies, we process data under:</p>
        <ul>
          <li>Consent</li>
          <li>Contractual necessity</li>
          <li>Legal obligations</li>
          <li>Legitimate interests</li>
        </ul>
      </section>

      <section class="legal-section">
        <h2>5. Email Communications</h2>
        <p>If you subscribe, we may send:</p>
        <ul>
          <li>Startup insights</li>
          <li>Funding opportunities</li>
          <li>Growth resources</li>
          <li>Product updates</li>
          <li>Event announcements</li>
        </ul>
        <p>You may unsubscribe at any time.</p>
      </section>

      <section class="legal-section">
        <h2>6. Cookies</h2>
        <p>We use cookies to:</p>
        <ul>
          <li>Improve website performance</li>
          <li>Remember preferences</li>
          <li>Analyse traffic</li>
          <li>Measure marketing effectiveness</li>
        </ul>
        <p>By using the Platform, you consent to cookie use as described in our Cookie Policy.</p>
      </section>

      <section class="legal-section">
        <h2>7. Data Sharing</h2>
        <p>We do not sell personal information.</p>
        <p>We may share information with trusted service providers such as:</p>
        <ul>
          <li>Hosting providers</li>
          <li>Email service providers</li>
          <li>Analytics platforms</li>
          <li>CRM systems</li>
          <li>Payment processors</li>
        </ul>
        <p>where necessary to operate the Platform.</p>
      </section>

      <section class="legal-section">
        <h2>8. Data Security</h2>
        <p>We implement appropriate technical and organisational measures to protect personal information from:</p>
        <ul>
          <li>Unauthorized access</li>
          <li>Disclosure</li>
          <li>Loss</li>
          <li>Misuse</li>
        </ul>
        <p>However, no online system can be guaranteed 100% secure.</p>
      </section>

      <section class="legal-section">
        <h2>9. Data Retention</h2>
        <p>We retain personal information only for as long as necessary to:</p>
        <ul>
          <li>Provide services</li>
          <li>Meet legal obligations</li>
          <li>Resolve disputes</li>
          <li>Maintain business records</li>
        </ul>
      </section>

      <section class="legal-section">
        <h2>10. Your Rights</h2>
        <p>You may have the right to:</p>
        <ul>
          <li>Access personal information</li>
          <li>Correct inaccurate data</li>
          <li>Request deletion</li>
          <li>Restrict processing</li>
          <li>Object to processing</li>
          <li>Withdraw consent</li>
          <li>Request data portability</li>
        </ul>
        <p>To exercise these rights, contact us.</p>
      </section>

      <section class="legal-section">
        <h2>11. International Data Transfers</h2>
        <p>Where personal data is transferred outside the UK, we will use appropriate safeguards as required by applicable data protection laws.</p>
      </section>

      <section class="legal-section">
        <h2>12. Children's Privacy</h2>
        <p>UKStartupFlow is intended for users aged 18 and over.</p>
        <p>We do not knowingly collect personal data from children.</p>
      </section>

      <section class="legal-section">
        <h2>13. Updates to This Policy</h2>
        <p>We may update this Privacy Policy from time to time.</p>
        <p>Changes will be posted on this page with a revised effective date.</p>
      </section>

      <section class="legal-section">
        <h2>14. Contact Us</h2>
        <p>UKStartupFlow</p>
        <p>Email: <a href="mailto:privacy@ukstartupflow.com">privacy@ukstartupflow.com</a></p>
        <p>Website: <a href="/">ukstartupflow.com</a></p>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .legal-page {
    padding: 80px 0;
    background-color: #ffffff;
    min-height: 70vh;
  }

  .legal-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .legal-container h1 {
    font-size: 40px;
    font-weight: 800;
    color: #0b2242;
    margin-bottom: 8px;
    font-family: var(--font-heading, sans-serif);
  }

  .last-updated {
    font-size: 15px;
    color: #718096;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid #edf2f7;
  }

  .legal-section {
    margin-bottom: 40px;
  }

  .legal-section h2 {
    font-size: 22px;
    font-weight: 700;
    color: #0b2242;
    margin-bottom: 16px;
    font-family: var(--font-heading, sans-serif);
  }

  .legal-section h3 {
    font-size: 18px;
    font-weight: 600;
    color: #2d3748;
    margin-top: 24px;
    margin-bottom: 12px;
  }

  .legal-section p {
    font-size: 16px;
    color: #4a5568;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .legal-section ul {
    margin-top: 0;
    margin-bottom: 24px;
    padding-left: 24px;
    color: #4a5568;
  }

  .legal-section li {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 8px;
  }

  .legal-section a {
    color: #d6182a;
    text-decoration: none;
  }

  .legal-section a:hover {
    text-decoration: underline;
  }
</style>
