---
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">
          <img src="/images/logo_final_transparent.png" alt="UK Startup Flow" class="logo-image" />
        </a>
        <p class="footer-desc">Your trusted partner for starting, growing, and scaling your business in the UK.</p>
      </div>
      
      <div class="footer-links">
        <h4 class="footer-title">Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/start-journey">Start Your Journey</a></li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4 class="footer-title">Contact Us</h4>
        <ul>
          <li><a href="mailto:hello@ukstartupflow.com">hello@ukstartupflow.com</a></li>
          <li><a href="/contact">Support</a></li>
          <li class="static-text">London, United Kingdom</li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} UK Startup Flow. All rights reserved.</p>
      <div class="legal-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-subtle);
    padding: 4rem 0 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .logo-image {
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  .footer-desc {
    margin-top: 1rem;
    font-size: 0.95rem;
    max-width: 250px;
  }

  .footer-title {
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }

  .footer-links ul {
    list-style: none;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: 0.75rem;
  }

  .footer-links a, .static-text {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .legal-links {
    display: flex;
    gap: 1.5rem;
  }

  .legal-links a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .legal-links a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
