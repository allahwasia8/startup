---
---
<section class="hero-home">
  <!-- Background Image Placeholder (To be replaced with actual London image) -->
  <div class="hero-bg"></div>
  
  <div class="container hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="text-blue">Your flow.</span><br/>
        <span class="text-red">Your startup.</span><br/>
        <span class="text-blue">Your UK journey.</span>
      </h1>
      
      <p class="hero-subtitle">
        Everything you need to start, grow and scale<br/>
        your business in the UK.
      </p>
      
      <div class="hero-features">
        <div class="feature-item">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <span class="feature-text">Step-by-step<br/>guides</span>
        </div>
        <div class="feature-item">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <span class="feature-text">Expert<br/>resources</span>
        </div>
        <div class="feature-item">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
          </div>
          <span class="feature-text">Scale with<br/>confidence</span>
        </div>
      </div>
      
      <div class="hero-cta">
        <a href="/start-journey" class="btn-primary">Start Your Journey &rarr;</a>
        <a href="/resources" class="btn-secondary">Explore Resources</a>
      </div>
      
      <div class="hero-note">
        <p><strong>Built for founders.</strong> Backed by experience.</p>
        <div class="note-underline"></div>
      </div>
    </div>
  </div>

  <div class="trust-banner">
    <div class="container trust-container">
      <div class="trust-text">Trusted by founders across the UK</div>
      <div class="trust-logos">
        <span class="logo-placeholder">TechRound</span>
        <span class="logo-separator">|</span>
        <span class="logo-placeholder">Startups.co.uk</span>
        <span class="logo-separator">|</span>
        <span class="logo-placeholder">BUSINESS LDN</span>
        <span class="logo-separator">|</span>
        <span class="logo-placeholder">silicon canals</span>
        <span class="logo-separator">|</span>
        <span class="logo-placeholder">UKTN</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-home {
    position: relative;
    padding: 80px 0 0 0;
    background-color: #f8fbff;
    overflow: hidden;
    min-height: 700px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 65%;
    background-image: linear-gradient(to right, #f8fbff 0%, rgba(248,251,255,0.7) 30%, transparent 100%), url('/images/london-hero.jpg');
    background-size: cover;
    background-position: center right;
    z-index: 1;
    /* Adding a simulated ribbon overlay using gradients */
    mask-image: linear-gradient(to left, black, transparent);
    -webkit-mask-image: linear-gradient(to left, black, transparent);
  }
  
  .hero-bg::after {
    content: '';
    position: absolute;
    bottom: 10%;
    right: -10%;
    width: 120%;
    height: 150px;
    background: linear-gradient(to bottom, #d6182a 0%, #d6182a 33%, #ffffff 33%, #ffffff 66%, #0b2242 66%, #0b2242 100%);
    transform: rotate(-15deg);
    opacity: 0.8;
    z-index: 2;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 10;
    flex-grow: 1;
    display: flex;
    align-items: center;
  }

  .hero-content {
    max-width: 600px;
    padding: 40px 0 80px 0;
  }

  .hero-title {
    font-size: 56px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    font-family: var(--font-heading, sans-serif);
  }

  .text-blue {
    color: #0b2242;
  }

  .text-red {
    color: #d6182a;
  }

  .hero-subtitle {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.5;
    color: #4a5568;
    margin-bottom: 40px;
  }

  .hero-features {
    display: flex;
    gap: 32px;
    margin-bottom: 48px;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: #f0f4f8;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    color: #0b2242;
  }

  .feature-text {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    color: #2d3748;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    margin-bottom: 40px;
  }

  .btn-primary {
    background-color: #0b2242;
    color: #ffffff;
    border-radius: 8px;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .btn-primary:hover {
    background-color: #1a365d;
  }

  .btn-secondary {
    background-color: transparent;
    color: #0b2242;
    border: 1px solid #cbd5e0;
    border-radius: 8px;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-secondary:hover {
    background-color: #f7fafc;
    border-color: #0b2242;
  }

  .hero-note {
    font-size: 16px;
    color: #4a5568;
    display: inline-block;
  }

  .hero-note p {
    margin: 0;
  }
  
  .hero-note strong {
    color: #0b2242;
  }

  .note-underline {
    height: 3px;
    width: 40px;
    background-color: #d6182a;
    margin-top: 8px;
  }

  .trust-banner {
    background-color: #ffffff;
    border-top: 1px solid #e2e8f0;
    padding: 24px 0;
    position: relative;
    z-index: 10;
  }

  .trust-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }

  .trust-text {
    font-size: 14px;
    color: #718096;
    font-weight: 500;
  }

  .trust-logos {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .logo-placeholder {
    font-size: 16px;
    font-weight: 700;
    color: #a0aec0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: sans-serif;
  }

  .logo-separator {
    color: #e2e8f0;
  }

  @media (max-width: 992px) {
    .hero-title {
      font-size: 48px;
    }
    .hero-bg {
      opacity: 0.2;
      width: 100%;
    }
    .trust-container {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 40px;
    }
    .hero-features {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .feature-item {
      flex-direction: row;
      text-align: left;
      gap: 16px;
    }
    .feature-icon {
      margin-bottom: 0;
    }
    .hero-cta {
      flex-direction: column;
    }
    .btn-primary, .btn-secondary {
      text-align: center;
      width: 100%;
    }
  }
</style>
